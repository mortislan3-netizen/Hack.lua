-- Realistic Street Soccer - Full Hack Menu
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Ball = nil
local TargetGoal = nil
local LastDribbleTime = 0
local LastShootTime = 0
local LastSlideTime = 0
local LastTeleportTime = 0
local IsScriptActive = true

local Config = {
    Dribble = { Enabled = true, Range = 15, Cooldown = 0.1, FakeDirectionChance = 50 },
    Shoot = { Enabled = true, Range = 60, Power = 95, Accuracy = 98, PreferTopCorner = true, TopCornerChance = 90 },
    Slide = { Enabled = true, Range = 12, Cooldown = 0.8, StealChance = 95 },
    Speed = { Enabled = true, Multiplier = 3.5, StaminaBypass = true },
    Teleport = { Enabled = true, Range = 50, Cooldown = 0.05, SmoothTeleport = false }
}

local function FindBall()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == "Ball" or obj.Name == "SoccerBall" or obj.Name == "Top") then return obj end
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj:GetAttribute("IsBall") == true then return obj end
    end
    return nil
end

local function FindGoals()
    local goals = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == "Goal" or obj.Name == "Kale" or obj.Name == "Net") then table.insert(goals, obj) end
    end
    return goals
end

local function GetOpponents()
    local opponents = {}
    local myTeam = nil
    if LocalPlayer.Character then myTeam = LocalPlayer.Character:GetAttribute("Team") end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local playerTeam = player.Character:GetAttribute("Team")
            if myTeam == nil or playerTeam ~= myTeam then table.insert(opponents, player.Character) end
        end
    end
    return opponents
end

local function GetClosestOpponent(pos, range)
    local closest = nil
    local minDist = range or math.huge
    for _, opp in ipairs(GetOpponents()) do
        if opp:FindFirstChild("HumanoidRootPart") then
            local dist = (opp.HumanoidRootPart.Position - pos).Magnitude
            if dist < minDist then minDist = dist; closest = opp end
        end
    end
    return closest, minDist
end

local function GetTargetGoal()
    local goals = FindGoals()
    if #goals == 0 then return nil end
    local myGoal = nil
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = LocalPlayer.Character.HumanoidRootPart.Position
        local closestDist = math.huge
        for _, goal in ipairs(goals) do
            local dist = (goal.Position - myPos).Magnitude
            if dist < closestDist then closestDist = dist; myGoal = goal end
        end
    end
    for _, goal in ipairs(goals) do if goal ~= myGoal then return goal end end
    return goals[1]
end

local function GetTopCornerPosition(goal)
    if not goal then return nil end
    local goalSize = goal.Size
    local goalCFrame = goal.CFrame
    local topRight = goalCFrame * CFrame.new(goalSize.X/2, goalSize.Y/2, 0)
    local topLeft = goalCFrame * CFrame.new(-goalSize.X/2, goalSize.Y/2, 0)
    if math.random(1, 100) <= Config.Shoot.TopCornerChance then
        if math.random(1, 2) == 1 then return topRight.Position else return topLeft.Position end
    else return topRight.Position end
end

local function PerformDribble()
    if not Config.Dribble.Enabled then return end
    if tick() - LastDribbleTime < Config.Dribble.Cooldown then return end
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local closestOpp, dist = GetClosestOpponent(hrp.Position, Config.Dribble.Range)
    if not closestOpp then return end
    local oppHRP = closestOpp:FindFirstChild("HumanoidRootPart")
    if not oppHRP then return end
    local oppVelocity = oppHRP.Velocity
    local toUs = (hrp.Position - oppHRP.Position).Unit
    local oppSpeed = oppVelocity.Magnitude
    if oppSpeed > 5 and oppVelocity.Unit:Dot(toUs) > 0.3 then
        LastDribbleTime = tick()
        local randomAngle = math.rad(math.random(45, 90))
        if math.random(1, 100) <= Config.Dribble.FakeDirectionChance then randomAngle = -randomAngle end
        local escapeDirection = (hrp.Position - oppHRP.Position).Unit
        escapeDirection = escapeDirection * CFrame.Angles(0, randomAngle, 0)
        local newPos = hrp.Position + escapeDirection * 10
        character:MoveTo(newPos)
        if character:FindFirstChild("Humanoid") then character.Humanoid:Move(escapeDirection, true) end
    end
end

local function AutoShoot()
    if not Config.Shoot.Enabled then return end
    if tick() - LastShootTime < 1.5 then return end
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    local distToBall = (Ball.Position - hrp.Position).Magnitude
    if distToBall > 5 then return end
    TargetGoal = GetTargetGoal()
    if not TargetGoal then return end
    local distToGoal = (TargetGoal.Position - hrp.Position).Magnitude
    if distToGoal > Config.Shoot.Range then return end
    if distToGoal < Config.Shoot.Range then
        LastShootTime = tick()
        local targetPos
        if Config.Shoot.PreferTopCorner then targetPos = GetTopCornerPosition(TargetGoal) else targetPos = TargetGoal.Position + Vector3.new(0, TargetGoal.Size.Y/2, 0) end
        if targetPos then
            local shootDirection = (targetPos - Ball.Position).Unit
            local accuracyFactor = (100 - Config.Shoot.Accuracy) / 100
            local randomOffset = Vector3.new((math.random() - 0.5) * 2 * accuracyFactor * 5, (math.random() - 0.5) * 2 * accuracyFactor * 3, (math.random() - 0.5) * 2 * accuracyFactor * 5)
            shootDirection = (shootDirection + randomOffset).Unit
            local shootPower = Config.Shoot.Power * 10
            if Ball:IsA("BasePart") then
                Ball.Velocity = shootDirection * shootPower
                Ball.RotVelocity = Vector3.new(math.random(-20, 20), math.random(-20, 20), math.random(-20, 20))
            end
            if character:FindFirstChild("Humanoid") then
                local args = { [1] = "Shoot", [2] = shootDirection, [3] = Config.Shoot.Power }
                pcall(function()
                    local shootRemote = game:GetService("ReplicatedStorage"):FindFirstChild("ShootEvent")
                    if shootRemote then shootRemote:FireServer(unpack(args)) end
                end)
            end
        end
    end
end

local function AutoSlide()
    if not Config.Slide.Enabled then return end
    if tick() - LastSlideTime < Config.Slide.Cooldown then return end
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    local ballOwner = nil
    local opponents = GetOpponents()
    for _, opp in ipairs(opponents) do
        if opp:FindFirstChild("HumanoidRootPart") then
            local dist = (opp.HumanoidRootPart.Position - Ball.Position).Magnitude
            if dist < 5 then ballOwner = opp; break end
        end
    end
    if not ballOwner then return end
    local oppHRP = ballOwner:FindFirstChild("HumanoidRootPart")
    if not oppHRP then return end
    local distToOpp = (oppHRP.Position - hrp.Position).Magnitude
    if distToOpp <= Config.Slide.Range then
        LastSlideTime = tick()
        local slideDirection = (oppHRP.Position - hrp.Position).Unit
        if character:FindFirstChild("Humanoid") then
            pcall(function()
                local slideRemote = game:GetService("ReplicatedStorage"):FindFirstChild("SlideEvent")
                if slideRemote then slideRemote:FireServer(slideDirection) end
            end)
            local slidePos = hrp.Position + slideDirection * 8
            hrp.CFrame = CFrame.new(slidePos)
        end
        if math.random(1, 100) <= Config.Slide.StealChance then
            if Ball and character:FindFirstChild("HumanoidRootPart") then
                Ball.CFrame = character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -2)
                Ball.Velocity = Vector3.new(0, 0, 0)
                Ball.RotVelocity = Vector3.new(0, 0, 0)
            end
        end
    end
end

local function InfiniteSpeed()
    if not Config.Speed.Enabled then return end
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    if humanoid.WalkSpeed ~= 16 * Config.Speed.Multiplier then humanoid.WalkSpeed = 16 * Config.Speed.Multiplier end
    if Config.Speed.StaminaBypass then
        pcall(function()
            local stamina = character:FindFirstChild("Stamina") or character:FindFirstChild("Energy")
            if stamina and stamina:IsA("NumberValue") then stamina.Value = 100 end
            local staminaInt = character:FindFirstChild("StaminaInt")
            if staminaInt and staminaInt:IsA("IntValue") then staminaInt.Value = 100 end
        end)
    end
end

local function TeleportToBall()
    if not Config.Teleport.Enabled then return end
    if tick() - LastTeleportTime < Config.Teleport.Cooldown then return end
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    local distToBall = (Ball.Position - hrp.Position).Magnitude
    if distToBall > 0.5 and distToBall <= Config.Teleport.Range then
        LastTeleportTime = tick()
        local teleportPos = Ball.Position + Vector3.new(0, 3, 0)
        if Config.Teleport.SmoothTeleport then
            local tweenService = game:GetService("TweenService")
            local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
            local goal = {CFrame = CFrame.new(teleportPos)}
            local tween = tweenService:Create(hrp, tweenInfo, goal)
            tween:Play()
        else
            hrp.CFrame = CFrame.new(teleportPos)
        end
        Ball.Velocity = Vector3.new(0, 0, 0)
        Ball.RotVelocity = Vector3.new(0, 0, 0)
        Ball.CFrame = hrp.CFrame * CFrame.new(0, 0, -2)
    end
end

local function EnhancedBallControl()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    local dist = (Ball.Position - hrp.Position).Magnitude
    if dist > 3 and dist < 50 then
        local targetCFrame = hrp.CFrame * CFrame.new(0, 0, -2)
        Ball.CFrame = targetCFrame
        Ball.Velocity = Vector3.new(0, 0, 0)
        Ball.RotVelocity = Vector3.new(0, 0, 0)
        pcall(function()
            local ballOwner = Ball:FindFirstChild("Owner")
            if ballOwner then ballOwner.Value = LocalPlayer end
        end)
    end
    if dist > 1 and dist <= 3 then
        local direction = (hrp.Position - Ball.Position).Unit
        Ball.Velocity = direction * 30
    end
end

local function MainLoop()
    if not IsScriptActive then return end
    Ball = FindBall()
    TargetGoal = GetTargetGoal()
    pcall(InfiniteSpeed)
    pcall(TeleportToBall)
    pcall(PerformDribble)
    pcall(AutoShoot)
    pcall(AutoSlide)
    pcall(EnhancedBallControl)
end

local function CreateGUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SoccerHackGUI"
    screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    screenGui.ResetOnSpawn = false
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Size = UDim2.new(0, 250, 0, 350)
    mainFrame.Position = UDim2.new(0, 10, 0.5, -175)
    mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = screenGui
    local title = Instance.new("TextLabel")
    title.Text = "SOCCER HACK - v1.0"
    title.Size = UDim2.new(1, 0, 0, 30)
    title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    title.Parent = mainFrame

    local function CreateToggle(name, yPos, default, callback)
        local toggleFrame = Instance.new("Frame")
        toggleFrame.Size = UDim2.new(1, -20, 0, 30)
        toggleFrame.Position = UDim2.new(0, 10, 0, yPos)
        toggleFrame.BackgroundTransparency = 1
        toggleFrame.Parent = mainFrame
        local label = Instance.new("TextLabel")
        label.Text = name
        label.Size = UDim2.new(0.7, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = toggleFrame
        local button = Instance.new("TextButton")
        button.Text = default and "ON" or "OFF"
        button.Size = UDim2.new(0.3, 0, 1, 0)
        button.Position = UDim2.new(0.7, 0, 0, 0)
        button.BackgroundColor3 = default and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        button.TextSize = 14
        button.Parent = toggleFrame
        local state = default
        button.MouseButton1Click:Connect(function()
            state = not state
            button.Text = state and "ON" or "OFF"
            button.BackgroundColor3 = state and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
            callback(state)
        end)
        return button
    end

    CreateToggle("Dribbling (Calim)", 40, true, function(state) Config.Dribble.Enabled = state end)
    CreateToggle("Auto Shoot (Sut)", 75, true, function(state) Config.Shoot.Enabled = state end)
    CreateToggle("Auto Slide (Kayma)", 110, true, function(state) Config.Slide.Enabled = state end)
    CreateToggle("Speed Hack (Hiz)", 145, true, function(state) Config.Speed.Enabled = state end)
    CreateToggle("Teleport Ball (Isinlan)", 180, true, function(state) Config.Teleport.Enabled = state end)

    local closeButton = Instance.new("TextButton")
    closeButton.Text = "SCRIPTI KAPAT"
    closeButton.Size = UDim2.new(1, -20, 0, 40)
    closeButton.Position = UDim2.new(0, 10, 0, 300)
    closeButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeButton.TextSize = 16
    closeButton.Parent = mainFrame
    closeButton.MouseButton1Click:Connect(function() IsScriptActive = false; screenGui:Destroy() end)
end

local function SetupKeybinds()
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.F1 then IsScriptActive = not IsScriptActive end
        if input.KeyCode == Enum.KeyCode.F2 then Config.Dribble.Enabled = not Config.Dribble.Enabled end
        if input.KeyCode == Enum.KeyCode.F3 then Config.Shoot.Enabled = not Config.Shoot.Enabled end
        if input.KeyCode == Enum.KeyCode.F4 then Config.Slide.Enabled = not Config.Slide.Enabled end
        if input.KeyCode == Enum.KeyCode.F5 then Config.Speed.Enabled = not Config.Speed.Enabled end
        if input.KeyCode == Enum.KeyCode.F6 then Config.Teleport.Enabled = not Config.Teleport.Enabled end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(character)
    character:WaitForChild("HumanoidRootPart")
    LastDribbleTime = 0; LastShootTime = 0; LastSlideTime = 0; LastTeleportTime = 0
    Ball = FindBall(); TargetGoal = GetTargetGoal()
end)

LocalPlayer.OnTeleport:Connect(function(state)
    if state == Enum.TeleportState.Started then IsScriptActive = false end
end)

RunService.Heartbeat:Connect(MainLoop)
pcall(CreateGUI)
SetupKeybinds()
Ball = FindBall()
TargetGoal = GetTargetGoal()
