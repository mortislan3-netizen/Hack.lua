local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

local Ball = nil
local EnemyGoal = nil
local SlideEnabled = true
local TeleportEnabled = true
local ShootKey = Enum.KeyCode.E
local SlideKey = Enum.KeyCode.Q
local TeleportKey = Enum.KeyCode.R
local IsShooting = false
local IsSliding = false
local LastShoot = 0
local LastSlide = 0
local LastTeleport = 0

local function FindBall()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local n = v.Name:lower()
            if n:find("ball") or n:find("top") or n:find("soccer") then
                Ball = v
                return v
            end
        end
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") and v:GetAttribute("IsBall") then
            Ball = v
            return v
        end
    end
    return nil
end

local function FindEnemyGoal()
    local goals = {}
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            if v.Name:lower():find("goal") or v.Name:lower():find("kale") then
                table.insert(goals, v)
            end
        end
    end
    if #goals < 2 then EnemyGoal = goals[1]; return goals[1] end
    local char = LocalPlayer.Character
    if not char then EnemyGoal = goals[1]; return goals[1] end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then EnemyGoal = goals[1]; return goals[1] end
    local myPos = hrp.Position
    local closestToMe, minDist = nil, math.huge
    for _, g in ipairs(goals) do
        local d = (g.Position - myPos).Magnitude
        if d < minDist then minDist = d; closestToMe = g end
    end
    for _, g in ipairs(goals) do
        if g ~= closestToMe then EnemyGoal = g; return g end
    end
    EnemyGoal = goals[1]
    return goals[1]
end

local function GetTopCorner(shootPos)
    if not EnemyGoal then return nil end
    local cf = EnemyGoal.CFrame
    local sz = EnemyGoal.Size
    local rightCorner = (cf * CFrame.new(sz.X * 0.35, sz.Y * 0.85, 0)).Position
    local leftCorner = (cf * CFrame.new(-sz.X * 0.35, sz.Y * 0.85, 0)).Position
    local distToRight = (rightCorner - shootPos).Magnitude
    local distToLeft = (leftCorner - shootPos).Magnitude
    if distToRight < distToLeft then
        return rightCorner
    else
        return leftCorner
    end
end

local function ShootToCorner()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    if (Ball.Position - hrp.Position).Magnitude > 5 then return end
    if not EnemyGoal then EnemyGoal = FindEnemyGoal() end
    if not EnemyGoal then return end
    if tick() - LastShoot < 4 then return end
    LastShoot = tick()
    local targetPos = GetTopCorner(hrp.Position)
    if not targetPos then return end
    local shootDir = (targetPos - Ball.Position).Unit
    if Ball:IsA("BasePart") then
        Ball.Velocity = shootDir * 90
        Ball.AssemblyLinearVelocity = shootDir * 90
    end
end

local function SlideTackle()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    if tick() - LastSlide < 2.5 then return end
    local targetOpp = nil
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local ohrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if ohrp and (ohrp.Position - Ball.Position).Magnitude < 5 then
                if (ohrp.Position - hrp.Position).Magnitude < 15 then
                    targetOpp = plr.Character
                    break
                end
            end
        end
    end
    if not targetOpp then return end
    LastSlide = tick()
    local ohrp = targetOpp.HumanoidRootPart
    local dir = (ohrp.Position - hrp.Position).Unit
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.Sit = true
        hrp.AssemblyLinearVelocity = dir * 45
        task.wait(0.15)
        if (ohrp.Position - hrp.Position).Magnitude < 8 then
            Ball.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
            Ball.AssemblyLinearVelocity = Vector3.zero
        end
        task.wait(0.3)
        humanoid.Sit = false
    end
end

local function TeleportToBallFunc()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not Ball then Ball = FindBall() end
    if not Ball then return end
    local dist = (Ball.Position - hrp.Position).Magnitude
    if dist < 3 or dist > 100 then return end
    if tick() - LastTeleport < 1 then return end
    LastTeleport = tick()
    local targetCF = Ball.CFrame * CFrame.new(0, 0, 3)
    local rayOrigin = targetCF.Position + Vector3.new(0, 5, 0)
    local rayDir = Vector3.new(0, -15, 0)
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = {char}
    local hit = Workspace:Raycast(rayOrigin, rayDir, rp)
    if hit then
        targetCF = CFrame.new(targetCF.X, hit.Position.Y + 3.5, targetCF.Z)
    end
    local tween = TweenService:Create(hrp, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {CFrame = targetCF})
    tween:Play()
end

