UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == ShootKey then ShootToCorner() end
    if input.KeyCode == SlideKey then SlideTackle() end
    if input.KeyCode == TeleportKey then TeleportToBallFunc() end
end)

