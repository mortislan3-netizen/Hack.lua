        b.Size = UDim2.new(0.35,0,1,0)
        b.Position = UDim2.new(0.65,0,0,0)
        b.BackgroundColor3 = d and Color3.fromRGB(0,150,0) or Color3.fromRGB(150,0,0)
        b.TextColor3 = Color3.fromRGB(255,255,255)
