    cb.Position = UDim2.new(0,10,0,160)
    cb.BackgroundColor3 = Color3.fromRGB(180,0,0)
    cb.TextColor3 = Color3.fromRGB(255,255,255)
    cb.TextSize = 13
    cb.Parent = mf
    cb.MouseButton1Click:Connect(function() IsScriptActive = false sg:Destroy() end)
end

RunService.Heartbeat:Connect(MainLoop)
pcall(CreateGUI)
